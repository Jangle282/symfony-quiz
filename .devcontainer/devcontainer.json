{
    "name": "Symfony Quiz",
    "dockerComposeFile": "../docker-compose.yml",
    "service": "php",
    "runServices": ["php", "postgres", "nginx"],
    "workspaceFolder": "/srv/project",
    "customizations": {
        "vscode": {
            "settings": {
                "php.executablePath": "/usr/local/bin/php",
                "phpunit.config": "phpunit.dist.xml"
            },
            "extensions": [
                "DEVSENSE.phptools-vscode"
            ]
        }
    },
    "forwardPorts": [8080],
    "shutdownAction": "none"
}
